# Firebase Configuration
# Copy this file to .env and fill in your actual Firebase project values.
# These values are used by the mobile app (React Native/Expo) and are
# inlined into the client bundle, so treat EXPO_PUBLIC_* values as public.
#
# For EAS Builds/Updates:
# - GitHub Actions expects repository secrets with the same EXPO_PUBLIC_* names.
# - The CI workflow validates those values, syncs them into the EAS production
#   environment as sensitive variables, then builds/updates with --environment production.
# - For local CLI builds, either keep a local .env file or pull from EAS:
#     eas env:pull --environment production --path .env.local
#
# To set production values manually in EAS instead of through GitHub Actions:
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_API_KEY --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_DATABASE_URL --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_PROJECT_ID --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_APP_ID --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID --value "your_value" --visibility sensitive
#   eas env:create production --scope project --name EXPO_PUBLIC_GOOGLE_MAPS_API_KEY --value "your_value" --visibility sensitive

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your_project.firebasedatabase.app
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Maps API Key (required for Android maps)
# iOS uses Apple Maps natively and doesn't require an API key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

EXPO_PUBLIC_SUPPORT_PHONE=+441414876737
# Passenger login verifier settings
# App Check is OFF by default for passenger login verification.
# Set both flags to true later when App Check is fully configured in clients + backend.
EXPO_PUBLIC_VERIFY_PASSENGER_LOGIN_USE_APPCHECK=false
EXPO_PUBLIC_VERIFY_PASSENGER_LOGIN_REQUIRE_APPCHECK=false

