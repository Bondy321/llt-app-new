{
  "name": "lochlomondtravel",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo start --android",
    "android:dev": "expo start --dev-client --android",
    "ios": "expo start --ios",
    "ios:dev": "expo start --dev-client --ios",
    "web": "expo start --web",
    "test": "npm run test:all",
    "test:all": "npm run test:all:fast && npm run test:all:full",
    "test:all:fast": "npm run test:mobile:core && npm run test:web-admin",
    "test:all:full": "npm run test:mobile:extended",
    "test:all:with-emulators": "npm run test:all && npm run test:emulators",
    "test:mobile": "npm run test:mobile:core && npm run test:mobile:extended",
    "test:mobile:core": "npm run test:mobile:auth && npm run test:mobile:sync:contract && npm run test:mobile:services:booking && npm run test:mobile:ui:date-time",
    "test:mobile:extended": "npm run test:mobile:sync:engine && npm run test:mobile:services:chat && npm run test:mobile:services:photo && npm run test:mobile:services:notifications && npm run test:mobile:ux && npm run test:mobile:infra",
    "test:mobile:auth": "NODE_ENV=test node --test tests/loginFlow.test.js tests/LoginScreen.behavior.test.js tests/offlineLoginResolver.test.js tests/validateBookingReference.driver.test.js tests/validateBookingReference.passengerVerifier.test.js",
    "test:mobile:sync:contract": "NODE_ENV=test node --test tests/unifiedSyncStatus.test.js tests/manifestSyncState.test.js tests/passengerManifestSyncLabels.test.js tests/syncUiContract.test.js tests/uxAndBackend.contracts.test.js tests/tourHomeActionPlanner.test.js",
    "test:mobile:sync:engine": "NODE_ENV=test node --test tests/offlineSyncService.test.js __tests__/offlineSyncService.test.js __tests__/offlineQueueing.test.js __tests__/persistenceProvider.test.js",
    "test:mobile:services:booking": "NODE_ENV=test node --test tests/joinTour.test.js tests/driverAssignmentContract.test.js tests/assignDriverToTour.cleanup.test.js",
    "test:mobile:services:chat": "NODE_ENV=test node --test __tests__/chatService.test.js __tests__/chatRetry.test.js __tests__/chatUnreadSummary.test.js __tests__/chatReplyNavigation.test.js tests/chatSearch.test.js",
    "test:mobile:services:photo": "NODE_ENV=test node --test __tests__/photoService.test.js __tests__/photoService.pagination.test.js tests/imageOptimizationService.test.js",
    "test:mobile:services:notifications": "NODE_ENV=test node --test tests/notificationService.behavior.test.js",
    "test:mobile:ui:date-time": "NODE_ENV=test node --test tests/pickupTimeParser.test.js tests/itineraryDateParser.test.js tests/timeUtils.test.js",
    "test:mobile:ux": "NODE_ENV=test node --test tests/swipeHomeNavigation.test.js",
    "test:mobile:infra": "NODE_ENV=test node --test tests/firebase.initHealth.test.js tests/appMetadata.test.js __tests__/optionalServiceLoader.test.js",
    "test:web-admin": "npm --prefix web-admin run test",
    "test:emulators": "npm run test:emulators:firebase-rules",
    "test:emulators:firebase-rules": "firebase emulators:exec --project demo-llt-rules --only database \"node --test tests/firebaseRules/reactions.rules.test.js\"",
    "test:firebase:rules": "npm run test:emulators:firebase-rules",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios-device": "eas build --profile development-device --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "update:dev": "eas update --channel development",
    "update:prod": "eas update --channel production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "11.4.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.11",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "firebase": "^12.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "^5.4.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/register": "^7.28.6",
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase-tools": "^15.13.0",
    "react-test-renderer": "^19.1.0"
  },
  "private": true
}
