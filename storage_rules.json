rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Private photos - only the owner can read/write their own photos within a specific tour folder.
    match /private_tour_photos/{tourId}/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Group photos - any authenticated user can read and write to the shared tour album.
    match /group_tour_photos/{tourId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
