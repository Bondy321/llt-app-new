rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    function hasMatchingUploaderAuth() {
      return request.resource != null
        && request.resource.metadata.authUid == request.auth.uid
        && (resource == null || resource.metadata.authUid == request.auth.uid);
    }

    // NOTE:
    // Private photo ownership is enforced in Realtime Database using stable identity bindings
    // (booking refs / stable passenger IDs), which Storage rules cannot query directly.
    // For parity with that model and to prevent false denials, private objects are gated to
    // authenticated users + image constraints. Metadata/listing access remains constrained by
    // Realtime Database rules.
    match /private_tour_photos/{tourId}/{ownerId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isImageUpload() && hasMatchingUploaderAuth();
    }

    // Group tour photos (including nested thumbnails folders).
    match /group_tour_photos/{tourId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isImageUpload() && hasMatchingUploaderAuth();
    }
  }
}
